<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light">

    <!-- ── Blue AppBar — consistent with Doctor Dashboard ──────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            app:title="ClinicBook"
            app:titleTextColor="@color/white"
            app:menu="@menu/menu_receptionist_toolbar" />

    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Scrollable body ──────────────────────────────────────────────────── -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="32dp">

            <!-- ══════════════════════════════════════════════════ -->
            <!-- ── Hospital Banner + Identity Card ──────────────── -->
            <!-- ══════════════════════════════════════════════════ -->

            <!-- Banner image — full width, fixed height -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="200dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/hospital_banner"
                    android:scaleType="centerCrop"
                    android:contentDescription="Hospital Banner" />

                <!-- Subtle dark gradient at bottom so card reads cleanly -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_gravity="bottom"
                    android:background="@drawable/bg_banner_overlay" />

            </FrameLayout>

            <!-- ── Logo + Hospital Name identity card ─────────────────── -->
            <!-- Card floats up slightly over the bottom of the banner     -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-28dp"
                android:layout_marginBottom="4dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:paddingVertical="20dp"
                    android:paddingHorizontal="16dp">

                    <!-- Hospital Logo -->
                    <ImageView
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:src="@drawable/ic_medical_cross"
                        android:scaleType="centerInside"
                        android:tint="@color/primary"
                        android:contentDescription="Hospital Logo" />

                    <!-- Hospital Name -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="@string/hospital_name"
                        android:textColor="#111827"
                        android:textStyle="bold"
                        android:textSize="19sp"
                        android:gravity="center" />

                    <!-- Subtitle / Tagline -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/hospital_type"
                        android:textColor="#6B7280"
                        android:textSize="14sp"
                        android:gravity="center" />

                    <!-- Divider -->
                    <View
                        android:layout_width="48dp"
                        android:layout_height="2dp"
                        android:layout_marginTop="14dp"
                        android:background="@color/primary" />

                    <!-- "Good Day" badge -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Good Day 👋  Receptionist Panel"
                        android:textColor="@color/text_hint"
                        android:textSize="13sp"
                        android:gravity="center" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── Stats + Quick Actions ────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="20dp">

                <!-- Section label: TODAY'S OVERVIEW -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TODAY'S OVERVIEW"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="12dp" />

                <!-- Stat cards row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="28dp">

                    <!-- Total -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingVertical="18dp"
                            android:paddingHorizontal="8dp">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginBottom="8dp">
                                <View
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:background="@drawable/bg_action_circle_blue" />
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_calendar"
                                    android:tint="@color/primary"
                                    android:contentDescription="Total" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvTotalAppointments"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="@color/text_primary" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Total"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Pending -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingVertical="18dp"
                            android:paddingHorizontal="8dp">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginBottom="8dp">
                                <View
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:background="@drawable/bg_action_circle_amber" />
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_time"
                                    android:tint="@color/warning"
                                    android:contentDescription="Pending" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvPendingCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="@color/warning" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Pending"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Completed -->
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        app:cardBackgroundColor="@color/white">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:paddingVertical="18dp"
                            android:paddingHorizontal="8dp">

                            <FrameLayout
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_marginBottom="8dp">
                                <View
                                    android:layout_width="36dp"
                                    android:layout_height="36dp"
                                    android:background="@drawable/bg_action_circle_green" />
                                <ImageView
                                    android:layout_width="18dp"
                                    android:layout_height="18dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_check"
                                    android:tint="@color/success"
                                    android:contentDescription="Done" />
                            </FrameLayout>

                            <TextView
                                android:id="@+id/tvCompletedCount"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textSize="26sp"
                                android:textStyle="bold"
                                android:textColor="@color/success" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Done"
                                android:textSize="11sp"
                                android:textColor="@color/text_hint"
                                android:layout_marginTop="2dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Section label: QUICK ACTIONS -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="QUICK ACTIONS"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.10"
                    android:textColor="@color/text_hint"
                    android:layout_marginBottom="12dp" />

                <!-- Quick action cards row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="3">

                    <!-- Add Patient -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardAddPatient"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        app:cardBackgroundColor="@color/white"
                        app:rippleColor="@color/primary_light">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp">
                                <View
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_action_circle_green" />
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_person"
                                    android:tint="@color/success"
                                    android:contentDescription="Add Patient" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Add Patient"
                                android:textSize="11sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Book Appointment -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardBookAppointment"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        app:cardBackgroundColor="@color/white"
                        app:rippleColor="@color/primary_light">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp">
                                <View
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_action_circle_blue" />
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_calendar"
                                    android:tint="@color/primary"
                                    android:contentDescription="Book Appointment" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Book Appt."
                                android:textSize="11sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- View Appointments -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardViewAppointments"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_weight="1"
                        android:clickable="true"
                        android:focusable="true"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="@color/divider"
                        app:cardBackgroundColor="@color/white"
                        app:rippleColor="@color/primary_light">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:padding="12dp">

                            <FrameLayout
                                android:layout_width="40dp"
                                android:layout_height="40dp">
                                <View
                                    android:layout_width="40dp"
                                    android:layout_height="40dp"
                                    android:background="@drawable/bg_action_circle_amber" />
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:layout_gravity="center"
                                    android:src="@drawable/ic_patient"
                                    android:tint="@color/warning"
                                    android:contentDescription="View Appointments" />
                            </FrameLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="View Appts."
                                android:textSize="11sp"
                                android:textColor="@color/text_primary"
                                android:gravity="center"
                                android:layout_marginTop="8dp" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

<?xml version="1.0" encoding="utf-8"?>
<paths xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Covers Environment.getExternalStoragePublicDirectory(DIRECTORY_DOWNLOADS) on API ≤ 28 -->
    <external-path
        name="external_downloads"
        path="Download/" />
    <!-- Covers files in the app's private external storage (API 29+ MediaStore alternative) -->
    <external-files-path
        name="app_external_files"
        path="." />
</paths>

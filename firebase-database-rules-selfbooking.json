{
  "rules": {
    "users": {
      "$uid": {
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid"
      }
    },
    "patients": {
      ".read": "auth != null",
      ".write": "auth != null && !auth.token.firebase.sign_in_provider.matches('anonymous')"
    },
    "appointments": {
      ".read": "auth != null",
      "$appointmentId": {
        ".write": "auth != null",
        ".validate": "newData.hasChildren(['patientName', 'doctorName', 'time', 'status'])"
      }
    }
  }
}
